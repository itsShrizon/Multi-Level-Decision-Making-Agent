# --- runtime ---
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# --- CORS / hosts (JSON array syntax, since pydantic-settings parses it) ---
ALLOWED_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# --- LM providers ---
OPENAI_API_KEY=sk-replace-me
GEMINI_API_KEY=

# Per-tier model selection (provider/model). DSPy reads these.
LM_MAIN=openai/gpt-4o
LM_FAST=openai/gpt-4o-mini
LM_SUMMARY=openai/gpt-3.5-turbo
LM_REPORT=gemini/gemini-1.5-pro
LM_MAX_TOKENS=1024
LM_TEMPERATURE=0.0
LM_TIMEOUT_S=30

# --- storage ---
DATABASE_URL=postgresql+asyncpg://chatbot:password123@localhost:5432/chatbot_db
REDIS_URL=redis://localhost:6379/0

# --- limits ---
RATE_LIMIT=100/minute
MAX_CONVERSATION_HISTORY=500

# --- logs ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- observability (optional) ---
SENTRY_DSN=
